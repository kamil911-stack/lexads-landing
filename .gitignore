# ============================================================
# .gitignore — Workspace Jarvis
# ============================================================
# Ce qui doit RESTER en local et NE JAMAIS arriver sur GitHub.
# Ne pas alléger ce fichier sans réfléchir : une clé d'API qui fuit, c'est une
# clé à révoquer en urgence.
# ============================================================

# ----------------------------------------------------------
# Secrets & variables d'environnement
# ----------------------------------------------------------
.env
.env.*
!.env.example

# Clés et certificats (peu importe où ils traînent)
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer

# Fichiers JSON de credentials (Google service accounts, Firebase, etc.)
*-credentials.json
*-service-account.json
gcp-key.json

# ----------------------------------------------------------
# macOS / système
# ----------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ----------------------------------------------------------
# Éditeurs / IDE
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project

# ----------------------------------------------------------
# Dépendances
# ----------------------------------------------------------
node_modules/

# ----------------------------------------------------------
# Build
# ----------------------------------------------------------
dist/
build/
.next/

# ----------------------------------------------------------
# Logs et temp
# ----------------------------------------------------------
*.log
*.tmp
*.cache

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
.eggs/

# ----------------------------------------------------------
# Tests & couverture
# ----------------------------------------------------------
coverage/
.coverage
.pytest_cache/
htmlcov/

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
.env.docker
docker-compose.override.yml

# ----------------------------------------------------------
# Divers sensibles
# ----------------------------------------------------------
secrets/
credentials/
*.bak
*.orig
